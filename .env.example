# Production Environment Settings
ENVIRONMENT=production
DATABASE_URL=sqlite+aiosqlite:///./somessenger.db

# Security Keys (Generate new ones for your server)
SECRET_KEY=change_me_to_a_long_random_secret
MESSAGE_ENCRYPTION_KEY=change_me_to_a_fernet_key

# CORS Settings
# Add your domain and mobile origins here
CORS_ORIGINS=https://somessenger.ru,capacitor://localhost,http://localhost

# Token settings (43200 min = 30 days)
ACCESS_TOKEN_EXPIRE_MINUTES=43200
MAX_FILE_SIZE=52428800

# Initial Admin Account (Change password on first login)
DEFAULT_ADMIN_USERNAME=Art7235
DEFAULT_ADMIN_EMAIL=art7235@mail.ru
DEFAULT_ADMIN_DISPLAY_NAME=Art7235
DEFAULT_ADMIN_PASSWORD=change_me_immediately

# Official Channel
DEFAULT_CHANNEL_NAME=SoMessenger
DEFAULT_CHANNEL_USERNAME=somessenger
DEFAULT_CHANNEL_DESCRIPTION=Официальные новости SoMessenger

# SMTP Settings (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=m91730405@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here

# Admin Panel Security
ADMIN_PANEL_TOKEN=generate_a_random_token_here